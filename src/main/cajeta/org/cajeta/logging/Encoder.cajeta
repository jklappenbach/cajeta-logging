package org.cajeta.logging;

/**
 * Renders a `LogRecord` to one line's worth of bytes (no trailing newline — the
 * appender owns line termination). Non-templated interface with an array return,
 * so it dispatches cleanly through the current compiler (the `Hasher` shape).
 */
public interface Encoder {
    public #int8[] encode(LogRecord r);
}
